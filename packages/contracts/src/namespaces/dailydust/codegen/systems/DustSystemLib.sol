    return Systems.getSystem(self.toResourceId());
  }

  function _world() private view returns (IWorldCall) {
    return IWorldCall(StoreSwitch.getStoreAddress());
  }
}

/**
 * System Function Interfaces
 *
 * We generate an interface for each system function, which is then used for encoding system calls.
 * This is necessary to handle function overloading correctly (which abi.encodeCall cannot).
 *
 * Each interface is uniquely named based on the function name and parameters to prevent collisions.
 */

interface _setConfig_bytes32_string {
  function setConfig(bytes32 configKey, string memory value) external;
}

interface _setConfigByString_string_string {
  function setConfigByString(string memory configKeyString, string memory value) external;
}

interface _getConfig_bytes32 {
  function getConfig(bytes32 configKey) external;
}

interface _getConfigByString_string {
  function getConfigByString(string memory configKeyString) external;
}

interface _authorizeBooster_address_uint8_uint256 {
  function authorizeBooster(address programAddress, uint8 programType, uint256 maxBoostAmount) external;
}

interface _deauthorizeBooster_address {
  function deauthorizeBooster(address programAddress) external;
}

interface _updateBooster_address_uint256_bool {
  function updateBooster(address programAddress, uint256 newMaxBoostAmount, bool isActive) external;
}

interface _isBoosterAuthorized_address {
  function isBoosterAuthorized(address programAddress) external;
}

interface _getBooster_address {
  function getBooster(address programAddress) external;
}

interface _getMaxBoostAmount_address {
  function getMaxBoostAmount(address programAddress) external;
}

interface _initializeConfig {
  function initializeConfig() external;
}

interface _batchSetConfig_bytes32Array_stringArray {
  function batchSetConfig(bytes32[] memory configKeys, string[] memory values) external;
}

interface _deleteConfig_bytes32 {
  function deleteConfig(bytes32 configKey) external;
}

interface _setSystemPaused_bool {
  function setSystemPaused(bool isPaused) external;
}

interface _isSystemPaused {
  function isSystemPaused() external;
}

interface _getConfigKeyHash_string {
  function getConfigKeyHash(string memory configKeyString) external;
}

interface _configExists_bytes32 {
  function configExists(bytes32 configKey) external;
}

interface _configExistsByString_string {
  function configExistsByString(string memory configKeyString) external;
}

